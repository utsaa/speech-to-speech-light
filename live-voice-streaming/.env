OLLAMA_HOST=localhost
OLLAMA_PORT=11434
REF_AUDIO=assets/client_voice.wav
REF_TEXT="হ্যালো, কী করছ গো তুমি এখন, কী করছ গো তুমি?"
VOCAB_FILE=weights/vocab.txt
STT_LANGUAGE=bn
VAD_THRESHOLD=0.015

# --- TTS Inference Parameters ---
# For local testing on a weak GPU:
# TTS_NFE_STEP=8
# TTS_SPEED=0.9
# 
# For Runpod with 24GB VRAM (e.g. RTX 3090 / A10G):
# Use NFE=32 for highest quality. The big GPU will handle it in <2 seconds.
TTS_NFE_STEP=32
TTS_SPEED=1.0
TTS_CFG_STRENGTH=2.0
TTS_SWAY_COEF=-1.0
TTS_VOLUME_MULTIPLIER=4.0

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8080
